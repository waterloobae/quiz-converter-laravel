{
  "name": "waterloobae/quizconverter",
  "version": "1.0.0",
  "description": "Quiz converter for LMSs",
  "license": "MIT",
  "minimum-stability": "dev",
  "prefer-stable": true,
  "require": {
      "php": "^7.4|^8.0",
      "ext-zip": "*",
      "ext-json": "*",
      "illuminate/http": "^9.0|^10.0|^11.0|^12.0|^13.0",
      "illuminate/routing": "^9.0|^10.0|^11.0|^12.0|^13.0"
  },
  "suggest": {
      "h5p/h5p-core": "Required for H5PQuizGenerator",
      "h5p/h5p-editor": "Required for H5PQuizGenerator",
      "h5p/h5p-multi-choice": "Required for H5PQuizGenerator",
      "h5p/h5p-question-set": "Required for H5PQuizGenerator",
      "h5p/h5p-arithmetic-quiz": "Required for H5PQuizGenerator",
      "h5p/h5p-math-display": "Required for H5PQuizGenerator"
  },
  "autoload": {
      "psr-4": {
          "Waterloobae\\QuizConverter\\": "src/",
          "H5P\\": "vendor/h5p/h5p-core/"
      }
  },
  "config": {
    "allow-plugins": {
      "composer/installers": true
    }
  }
}
